# Google Gemini API for AI Chat Assistant
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Google Maps JS API for Polling Booth location
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Google Calendar API for adding reminders
NEXT_PUBLIC_GOOGLE_CALENDAR_CLIENT_ID=YOUR_GOOGLE_CALENDAR_CLIENT_ID_HERE
GOOGLE_CALENDAR_CLIENT_SECRET=YOUR_GOOGLE_CALENDAR_CLIENT_SECRET_HERE

# Google Translate API for multilingual support
GOOGLE_TRANSLATE_API_KEY=YOUR_GOOGLE_TRANSLATE_API_KEY_HERE